[color]
    ui = true
[color "diff"]
    meta = yellow
    frag = magenta bold
    commit = yellow bold
    old = red bold
    new = green bold
    whitespace = red reverse
[core]
    autocrlf = false
    eol = lf
    excludesfile = /home/florian/.gitignore_global
    whitespace = -trailing-space,-indent-with-non-tab,-tab-in-indent
    pager = diff-so-fancy | less --tabs=4 -RF
[init]
    defaultBranch = main
[interactive]
    diffFilter = diff-so-fancy --patch
[pull]
    rebase = false
[push]
    autoSetupRemote = true
[user]
    email = git@ffflorian.de
    name = Florian Imdahl
    signingkey = 0x4B98BD1A
